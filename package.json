{
  "name": "ts-monorepo-template",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "vitest",
    "lint": "eslint . && fallow dead-code",
    "lint:fix": "eslint . --fix && fallow fix --yes --no-create-config",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "fallow": "^2.96.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.9"
}
